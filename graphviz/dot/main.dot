digraph "starter" {
node [ fontsize = "12" ]
subgraph clusterLegend {
  label = "Legend";
  color = black;
  edge [ style = invis ];
  legendNode0 [ label = "Executable", shape = egg ];
  legendNode1 [ label = "Static Library", shape = octagon ];
  legendNode2 [ label = "Shared Library", shape = doubleoctagon ];
  legendNode3 [ label = "Module Library", shape = tripleoctagon ];
  legendNode4 [ label = "Interface Library", shape = pentagon ];
  legendNode5 [ label = "Object Library", shape = hexagon ];
  legendNode6 [ label = "Unknown Library", shape = septagon ];
  legendNode7 [ label = "Custom Target", shape = box ];
  legendNode0 -> legendNode1 [ style = solid ];
  legendNode0 -> legendNode2 [ style = solid ];
  legendNode0 -> legendNode3;
  legendNode1 -> legendNode4 [ label = "Interface", style = dashed ];
  legendNode2 -> legendNode5 [ label = "Private", style = dotted ];
  legendNode3 -> legendNode6 [ style = solid ];
  legendNode0 -> legendNode7;
}
    "node0" [ label = "app", shape = egg ];
    "node1" [ label = "app_library", shape = octagon ];
    "node2" [ label = "project_options", shape = pentagon ];
    "node1" -> "node2"  // app_library -> project_options
    "node3" [ label = "project_warnings", shape = pentagon ];
    "node1" -> "node3"  // app_library -> project_warnings
    "node0" -> "node1" [ style = dotted ] // app -> app_library
    "node4" [ label = "fmt::fmt", shape = pentagon ];
    "node0" -> "node4" [ style = dotted ] // app -> fmt::fmt
    "node5" [ label = "graphviz", shape = box ];
    "node6" [ label = "graphviz_dot", shape = box ];
    "node7" [ label = "graphviz_png", shape = box ];
    "node8" [ label = "header_only_lib", shape = pentagon ];
    "node8" -> "node4" [ style = dashed ] // header_only_lib -> fmt::fmt
    "node9" [ label = "lib", shape = octagon ];
    "node9" -> "node2" [ style = dotted ] // lib -> project_options
    "node9" -> "node3" [ style = dotted ] // lib -> project_warnings
    "node10" [ label = "range-v3::range-v3", shape = pentagon ];
    "node11" [ label = "range-v3::concepts", shape = pentagon ];
    "node12" [ label = "range-v3::meta", shape = pentagon ];
    "node11" -> "node12" [ style = dashed ] // range-v3::concepts -> range-v3::meta
    "node10" -> "node11" [ style = dashed ] // range-v3::range-v3 -> range-v3::concepts
    "node10" -> "node12" [ style = dashed ] // range-v3::range-v3 -> range-v3::meta
    "node9" -> "node10" [ style = dotted ] // lib -> range-v3::range-v3
    "node13" [ label = "test_app_library", shape = egg ];
    "node14" [ label = "GTest::gtest_main", shape = pentagon ];
    "node15" [ label = "GTest::gtest", shape = pentagon ];
    "node14" -> "node15" [ style = dashed ] // GTest::gtest_main -> GTest::gtest
    "node13" -> "node14" [ style = dotted ] // test_app_library -> GTest::gtest_main
    "node13" -> "node1" [ style = dotted ] // test_app_library -> app_library
    "node13" -> "node2" [ style = dotted ] // test_app_library -> project_options
    "node13" -> "node3" [ style = dotted ] // test_app_library -> project_warnings
    "node13" -> "node13"  // test_app_library -> test_app_library
    "node16" [ label = "test_header_only_lib", shape = egg ];
    "node16" -> "node14" [ style = dotted ] // test_header_only_lib -> GTest::gtest_main
    "node16" -> "node8" [ style = dotted ] // test_header_only_lib -> header_only_lib
    "node16" -> "node2" [ style = dotted ] // test_header_only_lib -> project_options
    "node16" -> "node3" [ style = dotted ] // test_header_only_lib -> project_warnings
    "node16" -> "node16"  // test_header_only_lib -> test_header_only_lib
    "node17" [ label = "test_lib", shape = egg ];
    "node17" -> "node14" [ style = dotted ] // test_lib -> GTest::gtest_main
    "node17" -> "node8" [ style = dotted ] // test_lib -> header_only_lib
    "node17" -> "node9" [ style = dotted ] // test_lib -> lib
    "node17" -> "node2" [ style = dotted ] // test_lib -> project_options
    "node17" -> "node3" [ style = dotted ] // test_lib -> project_warnings
    "node17" -> "node17"  // test_lib -> test_lib
    "node18" [ label = "uninstall", shape = box ];
}
