digraph "lib" {
node [ fontsize = "12" ]
    "node9" [ label = "lib", shape = octagon ];
    "node2" [ label = "project_options", shape = pentagon ];
    "node9" -> "node2" [ style = dotted ] // lib -> project_options
    "node3" [ label = "project_warnings", shape = pentagon ];
    "node9" -> "node3" [ style = dotted ] // lib -> project_warnings
    "node10" [ label = "range-v3::range-v3", shape = pentagon ];
    "node9" -> "node10" [ style = dotted ] // lib -> range-v3::range-v3
    "node11" [ label = "range-v3::concepts", shape = pentagon ];
    "node10" -> "node11" [ style = dashed ] // range-v3::range-v3 -> range-v3::concepts
    "node12" [ label = "range-v3::meta", shape = pentagon ];
    "node11" -> "node12" [ style = dashed ] // range-v3::concepts -> range-v3::meta
    "node12" [ label = "range-v3::meta", shape = pentagon ];
    "node10" -> "node12" [ style = dashed ] // range-v3::range-v3 -> range-v3::meta
}
